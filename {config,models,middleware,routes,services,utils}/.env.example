# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/auralink?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── ESP8266 Device Auth ───────────────────────────────────────
# Each physical device will use this shared key (or generate per-device keys via /api/esp/register)
DEVICE_API_KEY=esp_replace_with_a_secret_device_key_32chars

# ── Heartbeat ─────────────────────────────────────────────────
# Seconds before a device is marked OFFLINE (should be >= ESP ping interval + buffer)
HEARTBEAT_TIMEOUT_SECONDS=45
